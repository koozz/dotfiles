{
  "$schema": "https://opencode.ai/config.json",
  "disabled_providers": [
    "amazon-bedrock",
    "anthropic",
    "azure",
    "deepseek",
    "google",
    "google-vertex",
    "groq",
    "llama",
    "mistral",
    "morph",
    "openai",
    "openrouter",
    "vercel",
    "xai"
  ],
  "instructions": ["AGENTS.md", "CONTRIBUTING.md", ".github/CONTRIBUTING.md", ".github/copilot-instructions.md"],
  "mcp": {
    "atlassian-mcp-server": {
      "type": "remote",
      "enabled": false,
      "url": "https://mcp.atlassian.com/v1/sse",
      "headers": {
        "Authorization": "Bearer ${ATLASSIAN_API_KEY}"
      }
    },
    "duckduckgo-seach": {
      "type": "local",
      "enabled": false,
      "command": ["uvx", "duckduckgo-mcp-server"]
    },
    "fetch": {
      "type": "local",
      "enabled": false,
      "command": ["uvx", "mcp-server-fetch"]
    },
    "git": {
      "type": "local",
      "enabled": false,
      "command": ["uvx", "mcp-server-git"]
    },
    "github-local": {
      "type": "local",
      "enabled": true,
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "github-remote": {
      "type": "remote",
      "enabled": false,
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "sequential-thinking": {
      "type": "local",
      "enabled": false,
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "zig-docs": {
      "type": "local",
      "enabled": true,
      "command": [
        "bunx",
        "zig-mcp@latest",
        "--version",
        "master",
        "--update-policy",
        "manual"
      ]
    }
  },
  "share": "disabled",
  "theme": "tokyonight"
}
